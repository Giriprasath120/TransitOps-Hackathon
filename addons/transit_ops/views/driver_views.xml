<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ========================= -->
    <!-- Driver Tree View -->
    <!-- ========================= -->
    <record id="view_transit_driver_tree" model="ir.ui.view">
        <field name="name">transit.driver.tree</field>
        <field name="model">transit.driver</field>
        <field name="arch" type="xml">
            <tree string="Drivers">
                <field name="name"/>
                <field name="license_no"/>
                <field name="phone"/>
                <field name="license_expiry"/>
                <field name="status"/>
            </tree>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Driver Form View -->
    <!-- ========================= -->
    <record id="view_transit_driver_form" model="ir.ui.view">
        <field name="name">transit.driver.form</field>
        <field name="model">transit.driver</field>
        <field name="arch" type="xml">
            <form string="Driver">
                <sheet>

                    <group>
                        <group>
                            <field name="name"/>
                            <field name="license_no"/>
                        </group>

                        <group>
                            <field name="phone"/>
                            <field name="license_expiry"/>
                            <field name="status"/>
                        </group>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Driver Search View -->
    <!-- ========================= -->
    <record id="view_transit_driver_search" model="ir.ui.view">
        <field name="name">transit.driver.search</field>
        <field name="model">transit.driver</field>
        <field name="arch" type="xml">
            <search string="Search Drivers">

                <field name="name"/>
                <field name="license_no"/>
                <field name="phone"/>

                <separator/>

                <filter
                    name="available"
                    string="Available"
                    domain="[('status','=','available')]"/>

                <filter
                    name="on_trip"
                    string="On Trip"
                    domain="[('status','=','on_trip')]"/>

                <filter
                    name="inactive"
                    string="Inactive"
                    domain="[('status','=','inactive')]"/>

                <group expand="0" string="Group By">

                    <filter
                        string="Status"
                        context="{'group_by':'status'}"/>

                </group>

            </search>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Driver Window Action -->
    <!-- ========================= -->
    <record id="action_transit_driver" model="ir.actions.act_window">
        <field name="name">Drivers</field>
        <field name="res_model">transit.driver</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_transit_driver_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first driver.
            </p>
        </field>
    </record>

</odoo>
<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Fuel Log Tree View -->
    <record id="view_transit_fuel_log_tree" model="ir.ui.view">
        <field name="name">transit.fuel.log.tree</field>
        <field name="model">transit.fuel.log</field>
        <field name="arch" type="xml">
            <tree>
                <field name="vehicle_id"/>
                <field name="fuel_date"/>
                <field name="liters"/>
                <field name="amount"/>
                <field name="odometer"/>
            </tree>
        </field>
    </record>

    <!-- Fuel Log Form View -->
    <record id="view_transit_fuel_log_form" model="ir.ui.view">
        <field name="name">transit.fuel.log.form</field>
        <field name="model">transit.fuel.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>

                    <group>
                        <group>
                            <field name="vehicle_id"/>
                            <field name="fuel_date"/>
                        </group>

                        <group>
                            <field name="liters"/>
                            <field name="amount"/>
                            <field name="odometer"/>
                        </group>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <!-- Fuel Log Search View -->
    <record id="view_transit_fuel_log_search" model="ir.ui.view">
        <field name="name">transit.fuel.log.search</field>
        <field name="model">transit.fuel.log</field>
        <field name="arch" type="xml">
            <search>

                <field name="vehicle_id"/>
                <field name="fuel_date"/>

                <separator/>

                <filter
                    name="group_vehicle"
                    string="Vehicle"
                    context="{'group_by':'vehicle_id'}"/>

                <filter
                    name="group_fuel_date"
                    string="Fuel Date"
                    context="{'group_by':'fuel_date'}"/>

            </search>
        </field>
    </record>

    <!-- Fuel Log Window Action -->
    <record id="action_transit_fuel_log" model="ir.actions.act_window">
        <field name="name">Fuel Logs</field>
        <field name="res_model">transit.fuel.log</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_transit_fuel_log_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first fuel log.
            </p>
        </field>
    </record>

</odoo>